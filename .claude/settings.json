{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/harness-guard.mjs", "timeout": 10, "statusMessage": "harness 护栏检查" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/harness-guard.mjs", "if": "Bash(git commit*)", "timeout": 10 }
        ]
      }
    ]
  }
}
