# Site settings
# Login form is on SITE_BASE_URL (no separate login URL).
SITE_BASE_URL=
SITE_FORM_URL=
SITE_USERNAME=
SITE_PASSWORD=

# External supplier mapping file (CSV only, fixed columns).
# If empty, default path is data/local/vendor_mapping.csv
VENDOR_MAPPING_PATH=

# Runtime
DRY_RUN=true

# Comma-separated required fields
REQUIRED_FIELDS=full_name,id_number,birth_date,address

