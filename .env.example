# Local config for the TypeScript rewrite. Copy to .env (which is git-ignored).
# Real secrets MUST NOT be committed.

# LLM provider — vendor-agnostic, OpenAI-compatible. DeepSeek V4 is the current default,
# but the provider is config-only (swap base_url + model + key for any compatible API).
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_API_KEY=

# uTradeHub login — used ONLY by the gated integration test (SITE_E2E=1) on a dev machine.
# The app itself NEVER persists credentials (entered per run, memory only). Never commit real values.
SITE_BASE_URL=https://www.utradehub.or.kr/
SITE_USERNAME=
SITE_PASSWORD=
