{
  "name": "utradehub-automation",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "uTradeHub 구매확인서 draft-generation tool (TypeScript rewrite)",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.51",
    "ai": "^6.0.208",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  }
}
