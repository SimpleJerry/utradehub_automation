{
  "name": "utradehub-automation",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "description": "uTradeHub 구매확인서 draft-generation tool (TypeScript rewrite)",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix": "npm run lint:fix && npm run format",
    "agents:sync": "node scripts/sync-ruler-assets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "dev:web": "vite --config web/vite.config.ts",
    "dev:server": "tsx watch src/app/server/index.ts",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "build": "vite build --config web/vite.config.ts",
    "package": "node packaging/package.mjs",
    "start": "tsx src/app/server/index.ts",
    "agents:dry-run": "ruler apply --agents claude,codex --skills --subagents --dry-run --verbose"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@fastify/static": "^9.1.3",
    "ai": "^6.0.208",
    "fastify": "^5.8.5",
    "playwright-core": "^1.61.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  }
}
